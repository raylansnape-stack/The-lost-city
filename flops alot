<!DOCTYPE html>
<html>
<head>
<title>AAA Survival World</title>

<style>
body {margin:0; overflow:hidden; font-family:Arial;}

#ui{
position:absolute;
top:10px;
left:10px;
color:white;
background:rgba(0,0,0,0.5);
padding:10px;
}

#inventory{
position:absolute;
bottom:10px;
left:50%;
transform:translateX(-50%);
display:flex;
gap:10px;
}

.slot{
width:60px;
height:60px;
background:rgba(255,255,255,0.2);
border:2px solid white;
color:white;
display:flex;
align-items:center;
justify-content:center;
}

#craftMenu{
position:absolute;
right:20px;
top:50%;
transform:translateY(-50%);
background:rgba(0,0,0,0.8);
padding:15px;
color:white;
display:none;
width:200px;
}

</style>
</head>

<body>

<div id="ui">
WASD move | SHIFT sprint | SPACE jump<br>
Click = attack | Right click = bow<br>
C = Craft | B = Build | K = Save | L = Load
<br><span id="stats"></span>
</div>

<div id="inventory">
<div class="slot" id="s1"></div>
<div class="slot" id="s2"></div>
<div class="slot" id="s3"></div>
<div class="slot" id="s4"></div>
</div>

<div id="craftMenu">
<h3>Craft</h3>
<div id="recipes"></div>
<button onclick="toggleCraft()">Close</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/three@0.158.0/build/three.min.js"></script>

<script>

// ===== BASIC SETUP =====
let scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x88ccee, 0.002);

let camera = new THREE.PerspectiveCamera(75,innerWidth/innerHeight,0.1,1000);

let renderer = new THREE.WebGLRenderer();
renderer.setSize(innerWidth,innerHeight);
renderer.shadowMap.enabled = true;
document.body.appendChild(renderer.domElement);

// LIGHT
let sun = new THREE.DirectionalLight(0xffffff,1);
sun.position.set(50,100,50);
sun.castShadow = true;
scene.add(sun);

// PLAYER
let player = new THREE.Object3D();
player.position.set(0,5,0);
scene.add(player);
camera.position.set(0,2,0);
player.add(camera);

// ===== BIOME =====
function getBiome(x){
if(x < -50) return "snow";
if(x > 50) return "desert";
return "forest";
}

// ===== TERRAIN =====
let geo = new THREE.PlaneGeometry(500,500,100,100);
let pos = geo.attributes.position;

for(let i=0;i<pos.count;i++){
let x = pos.getX(i);
let biome = getBiome(x);
let h = Math.random()*2;
if(biome==="snow") h+=1;
if(biome==="desert") h*=0.5;
pos.setZ(i,h);
}

geo.computeVertexNormals();

let terrain = new THREE.Mesh(
geo,
new THREE.MeshStandardMaterial({color:0x4c9a2a})
);
terrain.rotation.x = -Math.PI/2;
scene.add(terrain);

// ===== ARRAYS =====
let trees=[], rocks=[], enemies=[], buildings=[], arrows=[];

// ===== INVENTORY =====
let inventory = {wood:0, stone:0, cactus:0, ice:0};
let health=100;

// ===== CREATE OBJECTS =====
function tree(x,z){
let t = new THREE.Mesh(
new THREE.CylinderGeometry(0.5,0.5,5),
new THREE.MeshStandardMaterial({color:0x8b5a2b})
);
t.position.set(x,2.5,z);
t.userData.type="tree";
scene.add(t);
trees.push(t);
}

function cactus(x,z){
let c = new THREE.Mesh(
new THREE.CylinderGeometry(1,1,5),
new THREE.MeshStandardMaterial({color:0x2ecc71})
);
c.position.set(x,2.5,z);
c.userData.type="cactus";
scene.add(c);
trees.push(c);
}

function ice(x,z){
let i = new THREE.Mesh(
new THREE.BoxGeometry(2,2,2),
new THREE.MeshStandardMaterial({color:0x99ccff})
);
i.position.set(x,1,z);
i.userData.type="ice";
scene.add(i);
rocks.push(i);
}

// ===== WORLD GEN =====
for(let i=0;i<200;i++){
let x=Math.random()*400-200;
let z=Math.random()*400-200;
let b=getBiome(x);

if(b==="forest") tree(x,z);
if(b==="desert") cactus(x,z);
if(b==="snow") ice(x,z);
}

// ===== INPUT =====
let keys={};
document.addEventListener("keydown",e=>{
keys[e.key.toLowerCase()]=true;

if(e.key==="b") build();
if(e.key==="c") toggleCraft();
if(e.key==="k") save();
if(e.key==="l") load();
});

document.addEventListener("keyup",e=>keys[e.key.toLowerCase()]=false);

document.addEventListener("click",attack);
document.addEventListener("contextmenu",e=>{
e.preventDefault();
shoot();
});

// ===== MOVEMENT =====
function move(){
let speed = keys["shift"] ? 0.6 : 0.3;
if(keys["w"]) player.position.z -= speed;
if(keys["s"]) player.position.z += speed;
if(keys["a"]) player.position.x -= speed;
if(keys["d"]) player.position.x += speed;
}

// ===== ATTACK =====
function attack(){
let ray=new THREE.Raycaster();
ray.setFromCamera(new THREE.Vector2(0,0),camera);

let hit=ray.intersectObjects([...trees,...rocks,...buildings,...enemies]);

if(hit.length){
let o=hit[0].object;

// resources
if(o.userData.type==="tree"){inventory.wood++;}
if(o.userData.type==="cactus"){inventory.cactus++;}
if(o.userData.type==="ice"){inventory.ice++;}

scene.remove(o);
}
}

// ===== BOW =====
function shoot(){
let a=new THREE.Mesh(
new THREE.CylinderGeometry(0.1,0.1,2),
new THREE.MeshBasicMaterial({color:0x333333})
);

let dir=new THREE.Vector3();
camera.getWorldDirection(dir);

a.position.copy(player.position);
a.userData={vel:dir.multiplyScalar(1),life:100};

scene.add(a);
arrows.push(a);
}

function updateArrows(){
arrows.forEach((a,i)=>{
a.position.add(a.userData.vel);
a.userData.vel.y-=0.01;
a.userData.life--;

if(a.userData.life<0){
scene.remove(a);
arrows.splice(i,1);
}
});
}

// ===== BUILD =====
function build(){
if(inventory.wood<5) return;

inventory.wood-=5;

let w=new THREE.Mesh(
new THREE.BoxGeometry(4,3,0.5),
new THREE.MeshStandardMaterial({color:0xc2b280})
);

w.position.set(player.position.x,2,player.position.z-5);
w.userData.health=100;

scene.add(w);
buildings.push(w);
}

// ===== CRAFT =====
let recipes={
wall:{wood:5},
bow:{wood:3},
armor:{ice:5}
};

function craft(item){
let r=recipes[item];

for(let k in r){
if(inventory[k]<r[k]) return;
}

for(let k in r){
inventory[k]-=r[k];
}

if(item==="armor") health+=50;
}

function renderRecipes(){
let div=document.getElementById("recipes");
div.innerHTML="";

for(let k in recipes){
let r=recipes[k];

let el=document.createElement("div");
el.innerHTML=`${k}<br>${JSON.stringify(r)}
<br><button onclick="craft('${k}')">Make</button><hr>`;
div.appendChild(el);
}
}

let craftOpen=false;

function toggleCraft(){
craftOpen=!craftOpen;
document.getElementById("craftMenu").style.display=
craftOpen?"block":"none";
renderRecipes();
}

// ===== SAVE =====
function save(){
localStorage.setItem("save",JSON.stringify({
x:player.position.x,
z:player.position.z,
inv:inventory
}));
}

function load(){
let d=JSON.parse(localStorage.getItem("save"));
if(!d) return;

player.position.x=d.x;
player.position.z=d.z;
inventory=d.inv;
}

// ===== UI =====
function ui(){
document.getElementById("stats").innerHTML=
"❤️ "+health;

s1.innerHTML="🌲 "+inventory.wood;
s2.innerHTML="🌵 "+inventory.cactus;
s3.innerHTML="❄️ "+inventory.ice;
s4.innerHTML="🪨 "+inventory.stone;
}

// ===== LOOP =====
function animate(){
requestAnimationFrame(animate);

move();
updateArrows();
ui();

renderer.render(scene,camera);
}

animate();

</script>
</body>
</html>
